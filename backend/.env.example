# AbuseIPDB API anahtarınızı buraya yazın.
# Anahtarı https://www.abuseipdb.com/account/api adresinden alabilirsiniz.
ABUSEIPDB_API_KEY=your_api_key_here

# VirusTotal API anahtarı (opsiyonel).
# Anahtarı https://www.virustotal.com/gui/my-apikey adresinden alabilirsiniz.
# Bu alanı boş bırakırsanız uygulama çalışmaya devam eder;
# VirusTotal sütunları "Yapılandırılmadı" olarak gösterilir.
VT_API_KEY=your_virustotal_api_key_here

# AlienVault OTX API anahtarı (opsiyonel).
# Anahtarı https://otx.alienvault.com/api adresinden alabilirsiniz.
# Bu alanı boş bırakırsanız veya silerseniz uygulama çalışmaya devam eder;
# OTX sütunları "Yapılandırılmadı" olarak gösterilir.
OTX_API_KEY=your_otx_api_key_here

# Backend sunucusunun dinleyeceği port (varsayılan: 3000)
PORT=3000
